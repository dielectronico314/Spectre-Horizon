<?xml version="1.0" encoding="UTF-8"?>
<!-- 这个是iqs主图的label，属性系统是sas/iqs/graph/sp-fft-default，在int SP_FFT_IQ2Spectrum::receiveData(const char *data, size_t len) 中更新（SpectrumTraceDataManager那里边属性系统的node是sas/iqs/graph/sp-fft-default/data-manager/）WTF-->
<label>
    <top>
        <item key="rbw" text="RBW(Graph Top)" type="frequency" trigger="data-manager/rbw" value="data-manager/rbw" />
        <!-- <item key="VBW" text="VBW(Graph Top)" type="frequency" filter="Device" profile="SAStudio.Profile.Device.VBW" /> -->
        <item key="detector" text="TraceDetector" type="enum" trigger="data-manager/sp-fft/detector" value="data-manager/sp-fft/detector" list="0=PosSample detection,1=Sample detection,2=PosPeak detection,3=NegPeak detection,4=RMS detection,5=Bypass detection"/>
    </top>
    <bottom>
        <item key="start" text="Start Frequency(Graph Bottom)" type="frequency" trigger="data-manager/start-frequency" value="data-manager/start-frequency" />
        <item key="span" text="AnalysisBW" type="frequency" trigger="data-manager/bandwidth" value="data-manager/bandwidth" />
        <item key="center" text="Center Frequency(Graph Bottom)" type="frequency" trigger="data-manager/center-frequency" value="data-manager/center-frequency" />
        <item key="stop" text="Stop Frequency(Graph Bottom)" type="frequency" trigger="data-manager/stop-frequency" value="data-manager/stop-frequency" />
    </bottom>
</label>

