{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "SigMF Metadata Contrato (v0.1)",
    "description": "Contrato estricto para los metadatos generados por Spectre-Horizon Harogic SDR.",
    "type": "object",
    "required": ["global", "captures", "annotations"],
    "properties": {
        "global": {
            "type": "object",
            "required": ["core:datatype", "core:sample_rate", "core:hw", "core:author", "core:version"],
            "properties": {
                "core:datatype": {
                    "type": "string",
                    "pattern": "^cf32_le$"
                },
                "core:sample_rate": {
                    "type": "number",
                    "minimum": 0
                },
                "core:hw": {
                    "type": "string"
                },
                "core:author": {
                    "type": "string"
                },
                "core:version": {
                    "type": "string"
                }
            }
        },
        "captures": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "core:sample_start",
                    "core:frequency",
                    "core:datetime",
                    "core:overflows",
                    "telemetry:duration_sec",
                    "telemetry:throughput_mbps",
                    "telemetry:size_mb"
                ],
                "properties": {
                    "core:sample_start": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "core:frequency": {
                        "type": "number",
                        "minimum": 0
                    },
                    "core:datetime": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "core:overflows": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "telemetry:duration_sec": {
                        "type": "number",
                        "minimum": 0
                    },
                    "telemetry:throughput_mbps": {
                        "type": "number",
                        "minimum": 0
                    },
                    "telemetry:size_mb": {
                        "type": "number",
                        "minimum": 0
                    }
                },
                "additionalProperties": false
            }
        },
        "annotations": {
            "type": "array"
        }
    },
    "additionalProperties": false
}
